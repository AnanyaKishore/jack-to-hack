class Main {
    function void main() {
        var Array input;
        var Array filterVals;
        var Conv conv;
        let input = Array.new(25);
        let input[0] = 1;
        let input[1] = 2;
        let input[2] = 3;
        let input[3] = 4;
        let input[4] = 5;
        let input[5] = 6;
        let input[6] = 7;
        let input[7] = 8;
        let input[8] = 9;
        let input[9] = 10;
        let input[10] = 11;
        let input[11] = 12;
        let input[12] = 13;
        let input[13] = 14;
        let input[14] = 15;
        let input[15] = 16;
        let input[16] = 17;
        let input[17] = 18;
        let input[18] = 19;
        let input[19] = 20;
        let input[20] = 21;
        let input[21] = 22;
        let input[22] = 23;
        let input[23] = 24;
        let input[24] = 25;
        
        let filterVals = Array.new(9);
        let filterVals[0] = 0;
        let filterVals[1] = 0;
        let filterVals[2] = 0;
        let filterVals[3] = 0;
        let filterVals[4] = 1;
        let filterVals[5] = 0;
        let filterVals[6] = 0;
        let filterVals[7] = 0;
        let filterVals[8] = 0;

        let conv = Conv.new(5);
        do conv.initFilter(filterVals);
        do conv.getArrayInput(input, 5);
        do conv.conv2d();

        do Output.printString("Output matrix is:");
        do Output.println();
        do conv.printOutput();

        do conv.dispose();
        do input.dispose();
        do filterVals.dispose();
        return;
    }
}